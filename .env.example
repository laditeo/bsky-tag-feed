# ─────────────────────────────────────────────────────────────
#  Bluesky Tag Feed — configuration
#  Copy this file to ".env" and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
# Port the HTTP feed server listens on. Railway/Render inject PORT automatically.
PORT=3000
FEEDGEN_LISTENHOST=0.0.0.0

# Public hostname where this service is reachable (no protocol, no trailing slash).
# Example on Railway: my-feed-production.up.railway.app
FEEDGEN_HOSTNAME=example.com

# The service DID. Leave empty to default to did:web:<FEEDGEN_HOSTNAME>.
# FEEDGEN_SERVICE_DID=did:web:example.com

# ── Firehose ────────────────────────────────────────────────
FEEDGEN_SUBSCRIPTION_ENDPOINT=wss://bsky.network
FEEDGEN_SUBSCRIPTION_RECONNECT_DELAY=3000

# ── Database (PostgreSQL) ───────────────────────────────────
# Railway/Render provide this automatically when you attach a Postgres plugin.
DATABASE_URL=postgresql://user:password@localhost:5432/bsky_feed
# Set to "true" when connecting to a Postgres that requires SSL (most external URLs).
DATABASE_SSL=false

# ── Feed identity (used by describeFeedGenerator + publish script) ──
# The DID of the account that owns/publishes the feed (at://<PUBLISHER_DID>/...).
FEEDGEN_PUBLISHER_DID=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx
# The record key (rkey) / short name of the feed on the publisher account.
FEED_RECORD_NAME=tag-feed

# ── Moderation labels (verdicts from a labeler service) ──────
# PRIMARY source: labels applied by a moderation labeler, NOT the author.
# Subscribes to <endpoint>/xrpc/com.atproto.label.subscribeLabels.
# Default endpoint/DID = the official Bluesky moderation labeler (mod.bsky.app).
FEED_LABELER_ENDPOINT=wss://mod.bsky.app
FEED_LABELER_DID=did:plc:ar7c4by46qjdydhdevvrndac
# Moderation label values to keep. Empty = labeler stream disabled.
# Real values seen on mod.bsky.app: porn, sexual, nudity, graphic-media,
# gore, corpse, self-harm, spam, nudity-nonconsentual, impersonation, ...
FEED_MOD_LABELS=porn,sexual,nudity,graphic-media

# ── Firehose filters (self-labels / hashtags / keywords) ─────
# These read the post record from the firehose (needed for text/tags, since
# the labeler stream carries no post text). Leave empty to skip the firehose.
#
# self-labels = content categories set by the AUTHOR (not moderation verdicts).
FEED_SELF_LABELS=

# Hashtags to match (with or without leading #).
FEED_HASHTAGS=

# Keywords matched as substrings of the post text.
FEED_KEYWORDS=

# Optional language gate (ISO codes, e.g. "en,ru"). Empty = any language.
FEED_LANGUAGES=

# How to combine the firehose categories above:
#   any = keep a post if it matches ANY configured category (union, recommended)
#   all = keep a post only if it matches EVERY configured category
FEED_MATCH_MODE=any

# ── Publish script only (npm run publishFeed) ───────────────
BLUESKY_HANDLE=you.bsky.social
BLUESKY_PASSWORD=xxxx-xxxx-xxxx-xxxx
FEED_DISPLAY_NAME=My Tag Feed
FEED_DESCRIPTION=Posts filtered from the firehose by tags and content labels.
# Optional local path to an avatar image (png/jpg) for the feed.
# FEED_AVATAR_PATH=./avatar.png
